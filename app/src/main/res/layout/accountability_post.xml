<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/accountability_post_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:paddingVertical="@dimen/post_padding_vertical"
    android:paddingHorizontal="@dimen/post_padding_horizontal"
    android:orientation="vertical">

    <TextView
        android:id="@+id/post_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Baking Buddy"
        android:textColor="@color/text_color"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/post_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="8dp"
        android:text="This is a description of whatever this user would like to do/accomplish. If the description is too longgg..."
        android:textColor="@color/text_color"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/username"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:text="username"
        android:textColor="@color/text_color"
        android:textSize="12sp" />

</LinearLayout>