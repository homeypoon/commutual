<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F5F5"
    android:orientation="vertical"
    android:paddingStart="@dimen/home_page_margin"
    android:paddingLeft="@dimen/home_page_margin"
    android:paddingTop="36dp"
    android:paddingEnd="@dimen/home_page_margin"
    android:paddingRight="@dimen/home_page_margin"
    android:paddingBottom="@dimen/home_page_margin">

    <TextView
        android:id="@+id/upcoming_meet_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/explore_color"
        android:padding="4dp"
        android:paddingStart="16dp"
        android:paddingLeft="16dp"
        android:text="@string/explore_header"
        android:textColor="@color/white"
        android:textSize="@dimen/header_font_size" />

    <androidx.recyclerview.widget.RecyclerView
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>